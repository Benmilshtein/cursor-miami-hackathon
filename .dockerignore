# Dependencies & install caches (always rebuilt in image)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Next.js - never copy stale host build into build context
.next
out
.turbo
.vercel

# Git & CI - not needed to build or run the app
.git
.github
.gitattributes

# Secrets & local env (inject at runtime via compose / orchestrator)
.env
.env.*
!.env.example

# Documentation & changelogs (smaller context, faster builds)
*.md

# Tests & coverage - not required for production image build
coverage
.nyc_output
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
vitest.config.ts.timestamp-*

# IDE & editor
.vscode
.idea
.cursor

# Docker metadata (image is built from this context; omit recursive copies)
Dockerfile.*
docker-compose*.yml
docker-compose*.yaml
.dockerignore

# Misc
.DS_Store
Thumbs.db
*.pem
*.log
tmp/
temp/
