# Copy to .env and fill in real values. Never commit .env.

# ── Supabase (Auth + Postgres host) ───────────────────────────────────────────
# Auth is handled by Supabase Auth; data is accessed directly via Drizzle.
# Get these from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Server-only (never expose to browser) — used to create staff accounts, etc.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Database connections ───────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → Database → Connection string

# Runtime (app queries) — pooled via Supavisor, port 6543.
# IMPORTANT (Vercel/serverless): use this IPv4 transaction-pooler host
# (…pooler.supabase.com:6543). Do NOT use the direct db.<ref>.supabase.co:5432
# endpoint — it is IPv6-only and Vercel functions are IPv4-only, so it cannot
# connect from production. The pooler also requires `prepare: false` (see db/index.ts).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# Migrations only (Drizzle Kit / startup script) — direct connection, port 5432
DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── App URL ───────────────────────────────────────────────────────────────────
# Base URL of this app (same origin as the browser uses)
NEXT_PUBLIC_APP_URL=https://your-domain.example

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated emails auto-promoted to super_admin on sign-in
SUPER_ADMIN_EMAILS=admin@example.com

# ── OAuth providers ───────────────────────────────────────────────────────────
# Configure GitHub & Google in the Supabase dashboard (Auth → Providers).
# OAuth client id/secret live in Supabase, NOT here. Set each provider's
# callback URL to: https://<project-ref>.supabase.co/auth/v1/callback

# ── Optional: email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
# From address when using Resend (e.g. "App <onboarding@resend.dev>")
EMAIL_FROM=

# ── SEO ───────────────────────────────────────────────────────────────────────
# Canonical public URL for SEO, sitemap, JSON-LD (production)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# ── TLS (local HTTPS) ─────────────────────────────────────────────────────────
# Set both to enable in-app HTTPS, omit for HTTP fallback
SSL_KEY_PATH=./certs/server.key
SSL_CERT_PATH=./certs/server.crt
