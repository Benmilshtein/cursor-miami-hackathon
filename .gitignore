# See https://help.github.com/articles/ignoring-files/

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing & coverage
/coverage
/.nyc_output

# Next.js
/.next/
/out/

# Production / other build targets
/build
/dist

# Runtime & OS
.DS_Store
Thumbs.db
*.pem
*.log
certs/
tmp/
temp/

# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Environment — keep templates (e.g. .env.example) committable
.env
.env.*
.env.local
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Tooling caches
.turbo
.eslintcache
.cache/

# IDE (local only; commit shared .vscode settings if your team relies on them)
.idea/
